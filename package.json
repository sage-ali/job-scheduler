{
  "name": "job-scheduler-starter",
  "version": "1.0.0",
  "description": "A fullstack NestJS job scheduler with Bull queues, TypeORM, and Redis",
  "author": "",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "worker:dev": "ts-node -r tsconfig-paths/register src/worker.ts",
    "worker:prod": "node dist/worker",
    "dev": "concurrently -n api,worker -c cyan,green \"pnpm start:dev\" \"pnpm worker:dev\"",
    "dev:4workers": "concurrently -n api,w1,w2,w3,w4 -c cyan,green,green.dim,yellow,yellow.dim \"pnpm start:dev\" \"pnpm worker:dev\" \"pnpm worker:dev\" \"pnpm worker:dev\" \"pnpm worker:dev\"",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "lint:check": "eslint \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "typeorm": "DOTENV_CONFIG_PATH=.env ts-node -r tsconfig-paths/register -r dotenv/config node_modules/typeorm/cli.js",
    "migration:generate": "pnpm run typeorm migration:generate -d src/database/data-source.ts",
    "migration:run": "pnpm run typeorm migration:run -d src/database/data-source.ts",
    "migration:revert": "pnpm run typeorm migration:revert -d src/database/data-source.ts",
    "migration:show": "pnpm run typeorm migration:show -d src/database/data-source.ts",
    "db:reset": "DOTENV_CONFIG_PATH=.env ts-node -r tsconfig-paths/register -r dotenv/config scripts/reset-db.ts",
    "seed:db": "ts-node -r tsconfig-paths/register scripts/seed-db.ts",
    "seed:live": "ts-node scripts/seed-live.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@hng-sdk/orm": "0.0.0",
    "@nestjs/bull": "^10.2.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/swagger": "^8.1.1",
    "@nestjs/typeorm": "^10.0.2",
    "bull": "^4.16.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "ioredis": "^5.4.1",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^13.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/bull": "^4.10.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.1",
    "@types/pino": "^7.0.5",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "concurrently": "^10.0.3",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^17.0.7",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  },
  "lint-staged": {
    "src/**/*.ts": "eslint --fix"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@scarf/scarf",
      "msgpackr-extract"
    ]
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/test-setup.ts"
    ],
    "moduleNameMapper": {
      "@common/(.*)": "<rootDir>/common/$1",
      "@config/(.*)": "<rootDir>/config/$1",
      "@constants/(.*)": "<rootDir>/constants/$1",
      "@modules/(.*)": "<rootDir>/modules/$1",
      "@queue/(.*)": "<rootDir>/queue/$1",
      "@worker/(.*)": "<rootDir>/worker/$1"
    }
  }
}
