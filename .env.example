NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=job_scheduler
DATABASE_SYNC=false
DATABASE_LOGGING=false
DATABASE_SSL=false

# Redis (shared by RedisService and Bull)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_USERNAME=
REDIS_TLS=false

# Logging
LOG_LEVEL=info

# Worker
QUEUE_CONCURRENCY=3
QUEUE_MAX_ATTEMPTS=3

# DLQ alert — email fires when DLQ entry count reaches this threshold
DLQ_ALERT_THRESHOLD=10
ALERT_EMAIL=admin@example.com
EMAIL_FROM=Job Scheduler <noreply@example.com>

# Swagger
SWAGGER_ENABLED=true
CORS_ORIGIN=*
